@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // vindo do server quando a conta não está ativada
    var showActivation = (ViewBag.ShowAtivacao == true && (TempData["ShowLogin"] == null));
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-header">
            <img src="~/images/logo.png" alt="Logo" class="brand" />
            <h2 class="auth-title">Portal Helpdesk</h2>
            <div class="auth-sub">Entre com suas credenciais</div>
        </div>

        <div class="auth-body">
            @if (TempData["Mensagem"] != null)
            {
                <div class="alert alert-info mb-3">@TempData["Mensagem"]</div>
            }

            <!-- BLOCO: LOGIN -->
            <div id="loginForm" class="@(showActivation ? "hidden" : "")">
                <form method="post" asp-action="Login" asp-controller="Account" onsubmit="return lockButton(this)">
                    @Html.AntiForgeryToken()

                    <div class="form-floating mb-3 position-relative">
                        <input type="email" class="form-control" id="email" name="email" placeholder=" "
                               required value="@((string)(ViewBag.Email ?? ""))" />
                        <label for="email">E-mail</label>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input type="password" class="form-control" id="senha" name="senha" placeholder=" " required />
                        <label for="senha">Senha</label>
                        <button type="button"
                                class="btn-eye"
                                aria-label="Mostrar senha"
                                aria-pressed="false"
                                onclick="togglePass('senha', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>

                    <button type="submit" class="btn btn-brand" id="btnLogin">
                        <span class="btn-text">Entrar</span>
                        <span class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                    </button>

                    @if (ViewBag.Erro != null && !(bool)(ViewBag.ShowAtivacao ?? false))
                    {
                        <div class="alert alert-danger mt-3 mb-0" role="alert">@ViewBag.Erro</div>
                    }
                </form>

                <div class="auth-links">
                    <a href="@Url.Action("EsqueciSenha", "Account")">Esqueci minha senha</a>
                    <a href="@Url.Action("Registrar", "Account")">Criar conta</a>
                </div>

                <div class="divider"></div>

                <div class="small-muted">Não recebeu o e-mail de ativação?</div>
                <div class="mt-2">
                    <button type="button" class="btn btn-link p-0" style="color: var(--brand);" onclick="showActivation()">
                        Reenviar ativação
                    </button>
                </div>
            </div>

            <!-- BLOCO: REENVIAR ATIVAÇÃO -->
            <div id="activationForm" class="@(showActivation ? "" : "hidden")">
                <form method="post" action="@Url.Action("ReenviarAtivacao","Account")" onsubmit="return lockButton(this)">
                    @Html.AntiForgeryToken()

                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="emailAtiv" name="email" placeholder="seu e-mail"
                               required value="@((string)(ViewBag.Email ?? ""))" />
                        <label for="emailAtiv">Informe seu e-mail</label>
                    </div>

                    <button type="submit" class="btn btn-brand" id="btnAtivar">
                        <span class="btn-text">Reenviar ativação</span>
                        <span class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                    </button>

                    @if (ViewBag.Erro != null && (bool)(ViewBag.ShowAtivacao ?? false))
                    {
                        <div class="alert alert-danger mt-3 mb-0" role="alert">@ViewBag.Erro</div>
                    }
                </form>

                <div class="mt-3">
                    <button type="button" class="btn btn-link p-0" style="color: var(--brand);" onclick="showLogin()">
                        Voltar ao login
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function showActivation() {
        document.getElementById('loginForm').classList.add('hidden');
        document.getElementById('activationForm').classList.remove('hidden');
        setTimeout(() => document.getElementById('emailAtiv')?.focus(), 50);
    }
    function showLogin() {
        document.getElementById('activationForm').classList.add('hidden');
        document.getElementById('loginForm').classList.remove('hidden');
        setTimeout(() => document.getElementById('email')?.focus(), 50);
    }

    // Alterna visibilidade da senha
      function togglePass(inputId, btn){
      const inp = document.getElementById(inputId);
      if (!inp) return;

      const isPwd = inp.type === 'password';
      inp.type = isPwd ? 'text' : 'password';

      // acessibilidade
      btn.setAttribute('aria-pressed', String(isPwd));
      btn.setAttribute('aria-label', isPwd ? 'Ocultar senha' : 'Mostrar senha');

      // troca o ícone Bootstrap
      const icon = btn.querySelector('i');
      if (icon){
        icon.classList.toggle('bi-eye', !isPwd);
        icon.classList.toggle('bi-eye-slash', isPwd);
      }
    }

    // Desabilita botão e mostra spinner para evitar duplo submit
    function lockButton(form) {
        const btn = form.querySelector('button[type="submit"]');
        if (btn) {
            btn.disabled = true;
            const spin = btn.querySelector('.spinner-border');
            if (spin) spin.classList.remove('d-none');
        }
        return true;
    }

    // Foco adequado ao abrir a página
    (function init() {
        const showActivation = @(showActivation.ToString().ToLower());
        if (showActivation) setTimeout(() => document.getElementById('emailAtiv')?.focus(), 50);
        else setTimeout(() => document.getElementById('email')?.focus(), 50);
    })();
</script>
