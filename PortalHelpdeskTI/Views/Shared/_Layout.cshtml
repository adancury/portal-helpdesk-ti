@if (TempData["MensagemSucesso"] != null)
{
    <div class="modal fade" id="modalMensagemSucesso" tabindex="-1" aria-labelledby="modalMensagemSucessoLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="modalMensagemSucessoLabel">Sucesso</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    @TempData["MensagemSucesso"]
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modal = new bootstrap.Modal(document.getElementById('modalMensagemSucesso'));
            modal.show();
            setTimeout(() => modal.hide(), 4000);
        });
    </script>
}
<!-- Popup genérico de mensagem (padrão SL) -->
<div id="popupMensagem" class="modal fade" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-body text-center p-4">
        <i class="bi bi-check-circle text-success display-4 mb-3" id="popupMensagemIcon"></i>
        <h5 class="mb-2" id="popupMensagemTitulo">Sucesso</h5>
        <p id="popupMensagemTexto">Operação concluída.</p>
        <button type="button" class="btn btn-success mt-3 px-4" id="popupMensagemBtn" data-bs-dismiss="modal">OK</button>
      </div>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Mostra estado de carregando no popup (icone girando, botão oculto)
  window.showPopupLoading = function (titulo = 'Processando', texto = 'Carregando...') {
    const el = document.getElementById('popupMensagem');
    if (!el) return;
    const icon = el.querySelector('.modal-body .bi');
    const btn  = el.querySelector('.modal-body .btn');

    // icone "loading"
    icon.className = 'bi bi-arrow-repeat text-info display-4 mb-3 spin';
    el.querySelector('#popupMensagemTitulo').textContent = titulo;
    el.querySelector('#popupMensagemTexto').textContent  = texto;
    // desabilita/esconde botão enquanto carrega
    btn.className = 'btn mt-3 px-4 btn-secondary';
    btn.disabled = true;
    btn.style.visibility = 'hidden';

    const modal = bootstrap.Modal.getOrCreateInstance(el, { backdrop: 'static', keyboard: false });
    modal.show();
  };

  // Atualiza popup para sucesso/erro e (opcional) redireciona depois de X ms
  window.updatePopupMensagem = function (titulo, texto, tipo = 'success', autoHideMs = 1200, redirectUrl) {
    const el = document.getElementById('popupMensagem');
    if (!el) return;
    const icon = el.querySelector('.modal-body .bi');
    const btn  = el.querySelector('.modal-body .btn');

    // reseta spinner
    icon.classList.remove('spin');
    icon.className = 'bi display-4 mb-3';
    btn.disabled = false;
    btn.style.visibility = 'visible';

    // estilo conforme tipo
    if (tipo === 'error') {
      icon.classList.add('bi-x-circle', 'text-danger');
      btn.className = 'btn mt-3 px-4 btn-danger';
    } else if (tipo === 'warning') {
      icon.classList.add('bi-exclamation-triangle', 'text-warning');
      btn.className = 'btn mt-3 px-4 btn-warning';
    } else if (tipo === 'info') {
      icon.classList.add('bi-info-circle', 'text-info');
      btn.className = 'btn mt-3 px-4 btn-info';
    } else {
      icon.classList.add('bi-check-circle', 'text-success');
      btn.className = 'btn mt-3 px-4 btn-success';
    }

    el.querySelector('#popupMensagemTitulo').textContent = titulo || 'Mensagem';
    el.querySelector('#popupMensagemTexto').textContent  = texto || '';

    const modal = bootstrap.Modal.getOrCreateInstance(el);

    if (autoHideMs && autoHideMs > 0) {
      setTimeout(() => {
        try { modal.hide(); } catch {}
        if (redirectUrl) window.location.href = redirectUrl;
      }, autoHideMs);
    } else if (redirectUrl) {
      // sem autoHide, redireciona ao clicar em OK
      btn.onclick = () => { modal.hide(); window.location.href = redirectUrl; };
    }
  };
</script>
<script>
  // tipo: 'success' | 'error' | 'warning' | 'info'
  window.showPopupMensagem = function (titulo, texto, tipo = 'success', autoHideMs = 3500) {
    const modalEl  = document.getElementById('popupMensagem');
    const tituloEl = document.getElementById('popupMensagemTitulo');
    const textoEl  = document.getElementById('popupMensagemTexto');
    const iconEl   = document.getElementById('popupMensagemIcon');
    const btnEl    = document.getElementById('popupMensagemBtn');
    if (!modalEl || !tituloEl || !textoEl || !iconEl || !btnEl) return;

    // reset visual
    iconEl.className = 'bi display-4 mb-3';
    btnEl.className  = 'btn mt-3 px-4';

    switch (tipo) {
      case 'error':
        iconEl.classList.add('bi-x-circle', 'text-danger');
        btnEl.classList.add('btn-danger');
        break;
      case 'warning':
        iconEl.classList.add('bi-exclamation-triangle', 'text-warning');
        btnEl.classList.add('btn-warning');
        break;
      case 'info':
        iconEl.classList.add('bi-info-circle', 'text-info');
        btnEl.classList.add('btn-info');
        break;
      default:
        iconEl.classList.add('bi-check-circle', 'text-success');
        btnEl.classList.add('btn-success');
        break;
    }

    tituloEl.textContent = titulo || 'Mensagem';
    textoEl.textContent  = texto || '';

    const modal = new bootstrap.Modal(modalEl, { backdrop: 'static', keyboard: true });
    modal.show();

    // auto-fecha se quiser
    if (autoHideMs && autoHideMs > 0) {
      setTimeout(() => {
        try { modal.hide(); } catch {}
      }, autoHideMs);
    }
  };
</script>
<script src="~/js/site.js" asp-append-version="true" defer></script>
@{
    // Esses TempData podem ser setados nas actions (ex.: Aprovar/Rejeitar)
    var toastMsg  = TempData["ToastMsg"]  as string;
    var toastTipo = TempData["ToastTipo"] as string; // 'success' | 'error' | 'warning' | 'info'
}
<script>
  document.addEventListener('DOMContentLoaded', function () {
    // 1) Mensagem vinda do servidor (RedirectToAction com TempData)
    var msgTemp  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(toastMsg  ?? ""));
    var tipoTemp = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(toastTipo ?? "success"));

    if (msgTemp) {
      window.showPopupMensagem('Aprovação', msgTemp, tipoTemp || 'success');
      return;
    }

    // 2) Mensagem vinda do client (sessionStorage) — usada na _DetalhesAprovacao
    var msg  = sessionStorage.getItem('aprovacao_msg');
    var tipo = sessionStorage.getItem('aprovacao_tipo') || 'success';
    if (msg) {
      sessionStorage.removeItem('aprovacao_msg');
      sessionStorage.removeItem('aprovacao_tipo');
      window.showPopupMensagem('Aprovação', msg, tipo);
    }
  });
</script>
@RenderSection("Scripts", required: false)
<script>
  // a cada 10 minutos, renova a sessão se a aba estiver aberta
  setInterval(() => { fetch('/ping', { cache: 'no-store' }); }, 10 * 60 * 1000);
</script>
<script>
window.showPopupMensagem = function (titulo, mensagem, tipo) {
  try {
    const el = document.getElementById('popupMensagem');
    if (!el) {
      console.warn('popupMensagem não encontrado no DOM');
      return;
    }

    // ajusta título e texto
    el.querySelector('#popupMensagemTitulo').textContent = titulo || 'Mensagem';
    el.querySelector('#popupMensagemTexto').textContent = mensagem || '—';

    // ajusta cor/ícone
    const icon = el.querySelector('.bi');
    icon.className = 'bi display-4 mb-3';
    if (tipo === 'error') icon.classList.add('bi-x-circle', 'text-danger');
    else icon.classList.add('bi-check-circle', 'text-success');

    // Mostra com Bootstrap (garante que existe antes)
    if (window.bootstrap) {
      const modal = bootstrap.Modal.getOrCreateInstance(el);
      modal.show();
      setTimeout(() => modal.hide(), 3500);
    } else {
      alert(mensagem);
    }
  } catch (e) {
    console.error('Erro no showPopupMensagem', e);
  }
};
</script>
</body>
</html>
