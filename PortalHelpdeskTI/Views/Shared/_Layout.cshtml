        .navbar-custom { background-color: var(--primary); }
        .navbar-custom .nav-link, .navbar-custom .navbar-brand { color: var(--primary-contrast); }
        .navbar-custom .nav-link:hover { color: #d1e7ff; /* ou var(--accent) se preferir */ }

        body { padding-top: 80px; } /* espaço para navbar fixa */

        .modal { z-index: 1055; }
        .modal-backdrop { z-index: 1040; }
        .navbar { z-index: 1030; }

        tr.destaque-animado { animation: destaque 2s ease-out; }

        /* Header mínimo para telas públicas */
        .minimal-header {
            position: fixed; top: 0; left: 0; right: 0;
            background: #004A80; color: #fff;
            height: 56px; display: flex; align-items: center;
            padding: 0 16px; z-index: 1040;
        }
        .minimal-header .brand {
            display: flex; align-items: center; gap: 8px; font-weight: 600;
        }
        .minimal-header img { height: 26px; }
        /* reduzir o padding-top quando header mínimo */
        body.layout-minimal { padding-top: 56px; }
    </style>

    @RenderSection("Styles", required: false)

    <script>
(function() {
  try {
    var stored = localStorage.getItem('theme'); // 'dark' | 'light' | null
    var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    var theme = stored || (prefersDark ? 'dark' : 'light');

    // Se usar Bootstrap 5.3+, aproveite:
    document.documentElement.setAttribute('data-bs-theme', theme);

    // Fallback: classe .dark para quem não usa data-bs-theme
    if (theme === 'dark') document.documentElement.classList.add('dark');
    else document.documentElement.classList.remove('dark');
  } catch(e) {}
})();
</script>


</head>
<body class="d-flex flex-column min-vh-100 @(/*classe por layout*/ "")">
@{
    var controller = Context.Request.RouteValues["controller"]?.ToString();
    var action = Context.Request.RouteValues["action"]?.ToString();

    var minimalActions = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "Login","Registrar","EsqueciSenha","RedefinirSenha",
        "ConfirmarEmail","ConfirmarEmailResultado","TokenExpirado"
    };

    bool isMinimal = controller == "Account" && minimalActions.Contains(action);

    int? usuarioId = null;
    string perfil = null;
    string nomeUsuario = null;

    // -------------- AQUI: declarar antes --------------
    string primeiroUltimo = null;

    if (!isMinimal)
    {
        usuarioId = Context.Session.GetInt32("UsuarioId");

        if (usuarioId != null)
        {
            using var scope = Context.RequestServices.CreateScope();
            var db = scope.ServiceProvider.GetService<AppDbContext>();
            var usuario = db?.Usuarios.FirstOrDefault(u => u.Id == usuarioId.Value);

            if (usuario != null)
            {
                perfil = usuario.Perfil;
                nomeUsuario = usuario.Nome;
            }
        }

        // montar nome curto
        primeiroUltimo = nomeUsuario;
        if (!string.IsNullOrWhiteSpace(nomeUsuario))
        {
            var partes = nomeUsuario.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (partes.Length > 1)
                primeiroUltimo = partes[0] + " " + partes[^1];
        }
    }
}

