@using PortalHelpdeskTI.Models.Quizzes
@model PortalHelpdeskTI.Models.Quizzes.Quiz
@{
    ViewData["Title"] = "Editar Quiz";
    if (ViewBag.Embed == true) { Layout = null; }
}
<div class="admin-quizzes">
    <h2 class="mb-3">Editar: @Model.Titulo</h2>

    <div class="section mb-3">
        <form asp-controller="AdminQuizzes" asp-action="Editar" asp-route-id="@Model.Id" asp-route-embed="1" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label">Título</label>
                <input asp-for="Titulo" class="form-control" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Descrição</label>
                <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Categoria</label>
                    <input asp-for="Categoria" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Tempo Limite (segundos)</label>
                    <input asp-for="TempoLimiteSegundos" class="form-control" type="number" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Nota de corte (%)</label>
                    <input asp-for="NotaCortePercentual" class="form-control" type="number" step="0.01" min="0" max="100" />
                </div>
                <div class="col-md-4 mb-3 d-flex align-items-center gap-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Publicado" type="checkbox" />
                        <label class="form-check-label" asp-for="Publicado">Publicado</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" asp-for="EmbaralharQuestoes" type="checkbox" />
                        <label class="form-check-label" asp-for="EmbaralharQuestoes">Embaralhar</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary">Salvar</button>
                <a class="btn btn-secondary" asp-controller="AdminQuizzes" asp-action="Index">Voltar</a>
            </div>
        </form>
    </div>

    <div class="section">
        <h4 class="mb-3">Questões</h4>

        <div class="mb-3">
            <form asp-controller="AdminQuizzes" asp-action="AdicionarQuestao" asp-route-quizId="@Model.Id" asp-route-embed="1" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-6">
                    <label class="form-label">Enunciado</label>
                    <input name="Enunciado" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipo</label>
                    <select name="Tipo" class="form-select">
                        <option value="@((int)TipoQuestao.UnicaEscolha)">Única escolha</option>
                        <option value="@((int)TipoQuestao.MultiplaEscolha)">Múltipla escolha</option>
                        <option value="@((int)TipoQuestao.VerdadeiroFalso)">Verdadeiro/Falso</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Ordem</label>
                    <input name="Ordem" type="number" class="form-control" value="1" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button class="btn btn-success w-100">Adicionar</button>
                </div>
            </form>
        </div>

        @foreach (var q in Model.Questoes.OrderBy(x => x.Ordem))
        {
            <div class="mb-3 p-3 border rounded">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">(@q.Ordem) @q.Enunciado <small class="text-muted">[@q.Tipo]</small></h5>
                    <form asp-controller="AdminQuizzes" asp-action="RemoverQuestao" asp-route-questaoId="@q.Id" asp-route-embed="1" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover esta questão?');">Remover</button>
                    </form>
                </div>

                <div class="mt-2">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr><th>Opção</th><th>Correta</th><th>Ordem</th><th style="width:100px;"></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var o in q.Opcoes.OrderBy(x => x.Ordem))
                            {
                                <tr>
                                    <td>@o.Texto</td>
                                    <td>@(o.Correta ? "✔" : "—")</td>
                                    <td>@o.Ordem</td>
                                    <td class="text-end">
                                        <form asp-controller="AdminQuizzes" asp-action="RemoverOpcao" asp-route-opcaoId="@o.Id" asp-route-embed="1" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-danger">Remover</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <form asp-controller="AdminQuizzes" asp-action="AdicionarOpcao" asp-route-questaoId="@q.Id" asp-route-embed="1" method="post" class="row g-2">
                        @Html.AntiForgeryToken()
                        <div class="col-md-7">
                            <input name="Texto" class="form-control" placeholder="Texto da opção" required />
                        </div>
                        <div class="col-md-2">
                            <select name="Correta" class="form-select">
                                <option value="false">Errada</option>
                                <option value="true">Correta</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <input name="Ordem" type="number" class="form-control" value="1" />
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-primary w-100">Adicionar</button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
