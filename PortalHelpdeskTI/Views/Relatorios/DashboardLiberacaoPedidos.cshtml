        document.addEventListener('DOMContentLoaded', function () {
            const select = document.getElementById('filtro-status');
            const table = document.getElementById('tabela-painel');
            if (!table) return;

            const tbody = table.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));

            const pageSize = 20;
            let currentPage = 1;
            let lastTotalPages = 1;

            const lblTotal = document.getElementById('lbl-total');
            const lblPaginaAtual = document.getElementById('lbl-pagina-atual');
            const lblTotalPaginas = document.getElementById('lbl-total-paginas');
            const btnPrev = document.getElementById('btn-prev');
            const btnNext = document.getElementById('btn-next');

            function normalizarTexto(txt) {
                if (!txt) return '';
                return txt.replace(/\s+/g, ' ').trim().toLowerCase();
            }

            // ==============================
            // NOVO: mostra/esconde a coluna "Obs. devolução"
            // ==============================
            function toggleColDevolucao(show) {
                // Thead + tbody (th/td) usando a mesma classe
                document.querySelectorAll('.col-dev-comments').forEach(el => {
                    el.classList.toggle('d-none', !show);
                });
            }

            function setColunasDevolucaoVisiveis(visivel) {
                document.querySelectorAll('.col-dev-serial, .col-dev-comments').forEach(el => {
                    if (visivel) el.classList.remove('d-none');
                    else el.classList.add('d-none');
                });
            }


            function aplicarFiltroEPaginacao() {
                const filtroValor = select ? normalizarTexto(select.value) : '';
                const isDev = (filtroValor === 'devolvido');
                    setColunasDevolucaoVisiveis(isDev);
                const filtradas = [];

                // ==============================
                // NOVO: coluna só aparece quando filtro = "Devolvido"
                // ==============================
                toggleColDevolucao(filtroValor === 'devolvido');

                // Primeiro, filtra
                rows.forEach(row => {

                    let match = true; // por padrão, inclui

                    if (filtroValor) {
                        if (filtroValor === 'devolvido') {
                            // 👇 Para "Devolvido" usamos o StatusDocumento (data-status-doc)
                            const statusDoc = normalizarTexto(row.getAttribute('data-status-doc') || '');
                            match = (statusDoc === 'devolvido');
                        } else {
                            // 👇 Para os demais, usamos o texto da coluna STATUS (última coluna)
                            const statusCell = row.querySelector('td.col-status span');
                            if (!statusCell) {
                                match = false;
                            } else {
                                const textoStatus = normalizarTexto(statusCell.textContent);
                                match = (textoStatus === filtroValor);
                            }
                        }
                    }

                    if (match) {
                        filtradas.push(row);
                    } else {
                        row.style.display = 'none';
                    }
                });

                const totalFiltradas = filtradas.length;
                let totalPages = totalFiltradas > 0 ? Math.ceil(totalFiltradas / pageSize) : 1;
                if (currentPage > totalPages) currentPage = totalPages;

                // Depois, aplica a paginação
                filtradas.forEach((row, index) => {
                    const inicio = (currentPage - 1) * pageSize;
                    const fim = currentPage * pageSize;
                    if (index >= inicio && index < fim) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });

                // Atualiza os labels
                if (lblTotal) {
                    lblTotal.textContent = totalFiltradas.toString();
                }
                if (lblPaginaAtual) {
                    lblPaginaAtual.textContent = totalFiltradas === 0 ? '0' : currentPage.toString();
                }
                if (lblTotalPaginas) {
                    lblTotalPaginas.textContent = totalFiltradas === 0 ? '0' : totalPages.toString();
                }

                // Atualiza estado dos botões
                lastTotalPages = totalPages;

                if (btnPrev) {
                    btnPrev.disabled = (totalFiltradas === 0 || currentPage <= 1);
                }
                if (btnNext) {
                    btnNext.disabled = (totalFiltradas === 0 || currentPage >= totalPages);
                }
            }

            // Eventos de navegação
            if (btnPrev) {
                btnPrev.addEventListener('click', function () {
                    if (currentPage > 1) {
                        currentPage--;
                        aplicarFiltroEPaginacao();
                    }
                });
            }

            if (btnNext) {
                btnNext.addEventListener('click', function () {
                    if (currentPage < lastTotalPages) {
                        currentPage++;
                        aplicarFiltroEPaginacao();
                    }
                });
            }

            // Evento de filtro
            if (select) {
                select.addEventListener('change', function () {
                    currentPage = 1;
                    aplicarFiltroEPaginacao();
                });
            }

            // Primeira carga
            aplicarFiltroEPaginacao();
        });
    </script>

    <script>
        (function () {
            const hidden = document.getElementById('filtro-depto-hidden');
            const checkboxes = document.querySelectorAll('.filtro-depto-opcao');
            const label = document.getElementById('lbl-filtro-depto');

            function atualizarHiddenELegenda() {
                const selecionados = [];
                checkboxes.forEach(ch => {
                    if (ch.checked) selecionados.push(ch.value);
                });

                hidden.value = selecionados.join(',');

                if (selecionados.length === 0) {
                    label.textContent = 'Departamentos: Todos';
                } else if (selecionados.length === 1) {
                    label.textContent = 'Departamentos: ' +
                        (selecionados[0] === 'COMERCIAL' ? 'Comercial' : 'Financeiro');
                } else {
                    label.textContent = 'Departamentos: Comercial + Financeiro';
                }
            }

            checkboxes.forEach(ch => {
                ch.addEventListener('change', atualizarHiddenELegenda);
            });

            // Inicializa texto conforme o que veio do servidor
            atualizarHiddenELegenda();
        })();
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (tooltipTriggerEl) {
                new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.liberacao-card-inner[data-filtro]')
                .forEach(function (card) {
                    card.addEventListener('click', function () {
                        const filtro = this.getAttribute('data-filtro');
                        filtrarGridPorStatus(filtro);
                    });
                });
        });
    </script>

    <script>
        // Função global chamada ao clicar nos cards
        function filtrarGridPorStatus(filtro) {
            const select = document.getElementById('filtro-status');
            if (!select) return;

            switch (filtro) {
                case 'Total':
                    select.value = '';
                    break;
                case 'DentroSla':
                    select.value = 'Liberado dentro do SLA';
                    break;
                case 'ComAtraso':
                    select.value = 'Liberado com atraso';
                    break;
                case 'SemBloqueio':
                    select.value = 'Sem bloqueio';
                    break;
                case 'Pendencias':
                    select.value = 'Pendente';
                    break;
                case 'Recusado':
                    select.value = 'Recusado';
                    break;
                case 'Devolvidos':
                    select.value = 'Devolvido';   // 👈 importante
                    break;
                default:
                    select.value = '';
                    break;
            }

            const evt = new Event('change');
            select.dispatchEvent(evt);
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.liberacao-card-inner[data-filtro]')
                .forEach(function (card) {
                    card.addEventListener('click', function () {
                        const filtro = this.getAttribute('data-filtro');
                        filtrarGridPorStatus(filtro);
                    });
                });
        });
    </script>
}

