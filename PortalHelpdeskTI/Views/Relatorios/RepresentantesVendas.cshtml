@model PortalHelpdeskTI.ViewModels.Relatorios.DataTablePage
@{
    ViewData["Title"] = "Relatório – Representantes de Vendas";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var curPage = Model?.Page ?? 1;       // <- renomeado
    var pageSize = Model?.PageSize ?? 20;
    var q = Model?.Search ?? string.Empty;
}
<link rel="stylesheet" href="~/css/tecnico-painel.css" />

<div class="card shadow-sm rounded-4 card-representantes">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3 rep-header">
            <div>
                <h5 class="mb-0">Representantes de Vendas</h5>
                <div class="text-muted small">Fonte: ConsultasSQL/CadRepresentantes.sql</div>
            </div>
            <form id="frm-filtro" class="d-flex align-items-end gap-2" onsubmit="return false;">
                <div>
                    <label class="form-label small mb-1">Buscar</label>
                    <input type="text" class="form-control form-control-sm" name="q" value="@q" placeholder="Código, Nome, E-mail…" />
                </div>
                <div>
                    <label class="form-label small mb-1">Página</label>
                    <input type="number" class="form-control form-control-sm" name="page" value="@curPage" min="1" />
                </div>
                <div>
                    <label class="form-label small mb-1">Itens/página</label>
                    <input type="number" class="form-control form-control-sm" name="pageSize" value="@pageSize" min="20" step="20" />
                </div>
                <div class="d-flex gap-2">
                    <button id="btn-aplicar" class="btn btn-sm btn-primary">Aplicar</button>
                    <a class="btn btn-sm btn-outline-secondary" href="#" id="btn-export">Exportar CSV</a>
                </div>
                <div class="d-flex gap-2">
                    <button type="button"
                            class="btn btn-sm btn-outline-light"
                            onclick="history.back()">
                        ← Voltar
                    </button>
                </div>
            </form>
        </div>

        <div id="grid-wrapper">
            <partial name="_GridRepresentantesVendas_DataTable" model="Model" />
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
            const wrapper = document.getElementById('grid-wrapper');
            const form = document.getElementById('frm-filtro');

            async function carregar(p){
                const fd = new FormData(form);
                if(p) fd.set('page', p);
                const url = '@Url.Action("RepresentantesVendas", "Relatorios")' + '?' + new URLSearchParams(fd).toString();
                const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                wrapper.innerHTML = await resp.text();
            }

            document.getElementById('btn-aplicar')?.addEventListener('click', () => carregar());

            document.getElementById('btn-export')?.addEventListener('click', () => {
                const rows = [...document.querySelectorAll('#tabela-representantes tbody tr')].map(tr =>
                    [...tr.children].map(td => '"' + (td.innerText ?? '').replaceAll('"','""') + '"').join(',')
                );
                const header = [...document.querySelectorAll('#tabela-representantes thead th')].map(th =>
                    '"' + (th.innerText ?? '').replaceAll('"','""') + '"'
                ).join(',');
                const csv = [header, ...rows].join('\n');
                const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                const a = Object.assign(document.createElement('a'), { href: url, download: 'RepresentantesVendas.csv' });
                a.click(); URL.revokeObjectURL(url);
            });

            // paginação via delegação (links data-page na partial)
            document.addEventListener('click', e => {
                const a = e.target.closest('[data-page]');
                if(!a) return;
                e.preventDefault();
                const p = parseInt(a.getAttribute('data-page'), 10) || 1;
                carregar(p);
            });
        })();
    </script>
}
