@model PortalHelpdeskTI.Services.Relatorios.MudancaCarteiraResultado
@{
    ViewData["Title"] = "Resultado - Mudança de Carteira (Service Layer)";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-2">
    <h2 class="mb-0">Resultado - Mudança de Carteira</h2>
    <div class="text-muted">Processamento via Service Layer.</div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
        <strong>Resumo</strong>

        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-outline-primary"
               href="~/Relatorios/MudancaCarteira/ServiceLayer">
                Voltar para operações
            </a>

            <form class="m-0"
                  method="post"
                  action="~/Relatorios/MudancaCarteira/ServiceLayerLogout">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-secondary" type="submit">
                    Trocar usuário SAP
                </button>
            </form>
        </div>
    </div>

    <div class="card-body">
        <div class="row g-2">
            <div class="col-12 col-md-4">
                <div class="p-2 border rounded bg-body">
                    <div class="text-muted small">Total linhas</div>
                    <div class="fs-4">@Model.Total</div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="p-2 border rounded bg-body">
                    <div class="text-muted small">Atualizados</div>
                    <div class="fs-4">@Model.Atualizados</div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="p-2 border rounded bg-body">
                    <div class="text-muted small">Erros</div>
                    <div class="fs-4">@((Model.Erros?.Count) ?? 0)</div>
                </div>
            </div>
        </div>

        @if (Model.Erros != null && Model.Erros.Count > 0)
        {
            <hr class="my-3" />

            <div class="alert alert-warning mb-2">
                <strong>Ocorreram erros no processamento.</strong>
                Confira os detalhes abaixo.
            </div>

            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th style="min-width: 320px;">Mensagem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model.Erros)
                        {
                            <tr>
                                <td class="text-break">@e</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <hr class="my-3" />
            <div class="alert alert-success mb-0">
                Todas as linhas foram processadas com sucesso.
            </div>
        }

        <div class="mt-3 d-flex flex-wrap gap-2">
            <a class="btn btn-primary"
               href="~/Relatorios/MudancaCarteira/ServiceLayer">
                Novo processamento
            </a>

            <a class="btn btn-outline-secondary"
               href="~/Relatorios/MudancaCarteira/ServiceLayerLogin">
                Login SAP
            </a>
        </div>
    </div>
</div>
