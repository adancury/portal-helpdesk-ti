@model PortalHelpdeskTI.ViewModels.Relatorios.DataTablePage
@{
    var dt = Model.Data;
    var total = Model.Total;
    var ultimaAtualizacao = dt.ExtendedProperties["UltimaAtualizacaoPrevisao"] as DateTime?;
}

<div class="card card-ruptura-grid mb-3">
    <div class="card-header py-2 d-flex justify-content-between align-items-center gap-2 small">
        <div class="fw-semibold">Previsăo de ruptura</div>
        <div class="text-muted text-end">
            Última atualizaçăo:
            <strong>
                @(ultimaAtualizacao.HasValue
                    ? ultimaAtualizacao.Value.ToString("dd/MM/yyyy HH:mm")
                    : "năo disponível")
            </strong>
        </div>
    </div>

    <div class="table-wrap-rupturas-prev table-responsive mb-0">
        <table id="tabela-previsao"
               class="table table-sm align-middle mb-0 relatorio-table-rupturas-prev">
            <colgroup>
                <col style="width:120px;">   @* Código *@
                <col>                        @* Descriçăo *@
                <col style="width:150px;">   @* Fora de Linha *@
                <col style="width:110px;">   @* Data *@
                <col style="width:110px;">   @* EstoqueNoDia *@
                <col style="width:110px;">   @* QtdComprometida *@
                <col style="width:110px;">   @* QtdAReceber *@
                <col style="width:120px;">   @* EstoqueDisponivel *@
                <col style="width:90px;">    @* Status *@
            </colgroup>
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Produto</th>
                    <th>Fora de Linha</th>
                    <th>Data</th>
                    <th class="text-end">Estoque do Dia</th>
                    <th class="text-end">Qtd. Comprometida</th>
                    <th class="text-end">Qtd. a Receber</th>
                    <th class="text-end">Estoque Disponível</th>
                    <th class="text-center">Status</th>
                </tr>
            </thead>
            <tbody>
                @if (dt.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted">
                            Nenhum registro encontrado.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (System.Data.DataRow r in dt.Rows)
                    {
                        var status = r["Status"].ToString();
                        var css = status == "RUPTURA" ? "badge bg-danger" :
                        status == "OK" ? "badge bg-success" :
                        "badge bg-secondary";
                        <tr>
                            <td>@r["ItemCode"]</td>
                            <td>@r["ItemName"]</td>
                            <td>@r["ForaLinhaStatus"]</td>
                            <td>@(((DateTime)r["Data"]).ToString("dd/MM/yyyy"))</td>
                            <td class="text-end">@r["EstoqueNoDia"]</td>
                            <td class="text-end">@r["QtdComprometida"]</td>
                            <td class="text-end">@r["QtdAReceber"]</td>
                            <td class="text-end">@r["EstoqueDisponivel"]</td>
                            <td class="text-center"><span class="@css">@status</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (total > 0)
    {
        <div class="card-footer py-2 small">
            <div class="d-flex justify-content-between mb-1">
                <button class="btn btn-sm btn-outline-secondary" data-prev>« Anterior</button>
                <div>
                    Página <span data-atual>1</span> de <span data-total>1</span>
                </div>
                <button class="btn btn-sm btn-outline-secondary" data-next>Próxima »</button>
            </div>

            <div class="d-flex justify-content-between">
                <div>Total: <strong>@total</strong></div>
                <div data-rodape>Página 1</div>
            </div>
        </div>
    }
</div>
