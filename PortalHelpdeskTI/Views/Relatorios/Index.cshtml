@model PortalHelpdeskTI.Views.Relatorios.ReportsIndexVm
@{
    ViewData["Title"] = "Relatórios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/tecnico-painel.css" />

<div class="container-fluid py-3">
    <div class="row">
        <!-- Sidebar -->
        <aside class="col-12 col-md-3 col-lg-2 mb-3">
            <div class="card shadow-sm rounded-4 rel-sidebar">
                <div class="card-body p-2">
                    <div class="px-2 py-2 fw-semibold text-body-secondary small">Categorias</div>
                    <ul class="nav flex-column gap-1">
                        @foreach (var c in Model.Categorias)
                        {
                            var active = string.Equals(c, Model.CategoriaAtiva ?? "Todos", StringComparison.OrdinalIgnoreCase);
                            <li class="nav-item">
                                <a href="#" class="nav-link rel-side-link @(active ? "active" : "")" data-cat="@c">
                                    <span class="dot"></span> @c
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </aside>

        <!-- Conteúdo -->
        <section class="col-12 col-md-9 col-lg-10">
            <div class="rel-header d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                <div class="rel-header-left">
                    <h3 class="mb-0">Relatórios</h3>
                    <div class="text-body-secondary small">Acesse e baixe relatórios organizados por setores</div>
                </div>
                <div class="rel-header-right d-flex gap-2">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input id="txtBuscaRel" class="form-control" placeholder="Buscar relatórios..." value="@Model.Busca">
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">Período</button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#" data-period="any">Qualquer data</a></li>
                            <li><a class="dropdown-item" href="#" data-period="7d">Últimos 7 dias</a></li>
                            <li><a class="dropdown-item" href="#" data-period="30d">Últimos 30 dias</a></li>
                            <li><a class="dropdown-item" href="#" data-period="90d">Últimos 90 dias</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Grid de cards -->
            <div id="relGrid" class="row g-3">
                @foreach (var r in Model.Itens)
                {
                    var tempo = (DateTime.UtcNow - r.AtualizadoEm).TotalDays;
                    var tempoTxt = tempo < 1 ? "Há " + Math.Floor((DateTime.UtcNow - r.AtualizadoEm).TotalHours) + " horas"
                    : "Há " + Math.Floor(tempo) + " dias";
                    <div class="col-12 col-sm-6 col-xl-4"
                         data-cat="@r.Departamento"
                         data-updated="@r.AtualizadoEm.ToString("yyyy-MM-ddTHH:mm:ssZ")"
                         data-title="@r.Titulo.ToLower() @string.Join(' ', r.Tags).ToLower()">
                        <div class="card shadow-sm rounded-4 rel-card h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rel-icon">
                                            @if (string.Equals(r.Key, "INDICADOR_TI", StringComparison.OrdinalIgnoreCase))
                                            {
                                                if (r.KpiAtingiuMeta == true)
                                                {
                                                    <i class="bi bi-speedometer2 text-success"></i>
                                                }
                                                else if (r.KpiAtingiuMeta == false)
                                                {
                                                    <i class="bi bi-speedometer2 text-danger"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-speedometer2"></i>
                                                }
                                            }
                                            else
                                            {
                                                <i class="bi bi-file-earmark-text"></i>
                                            }
                                        </div>

                                        <h5 class="mb-0">@r.Titulo</h5>
                                    </div>
                                    @if (r.Favorito)
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    else
                                    {

                                        <i class="bi bi-star text-body-tertiary"></i>
                                    }
                                </div>

                                <p class="text-body-secondary small mb-2">@r.Descricao</p>

                                @if (string.Equals(r.Key, "INDICADOR_TI", StringComparison.OrdinalIgnoreCase) && r.KpiUltimoValorPct.HasValue)
                                {
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <span class="badge @(r.KpiAtingiuMeta == true ? "bg-success" : "bg-danger")">
                                            @(r.KpiBadgeTexto ?? (r.KpiAtingiuMeta == true ? "Meta 95% atingida" : "Meta 95% não atingida"))
                                        </span>

                                        <span class="badge bg-body-secondary text-body">
                                            Último mês: @r.KpiUltimoMes • @r.KpiUltimoValorPct.Value.ToString("N2")%
                                        </span>
                                    </div>
                                }

                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="badge bg-body-secondary text-body">@r.Departamento</span>
                                    <span class="badge bg-body-secondary text-body">@r.Formato</span>
                                    @foreach (var t in r.Tags)
                                    {
                                        <span class="badge bg-body-secondary text-body">@t</span>
                                    }
                                </div>

                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <div class="text-body-secondary small"><i class="bi bi-clock"></i> @tempoTxt</div>
                                    <div class="btn-group">
                                        @if (!string.IsNullOrWhiteSpace(r.UrlVisualizar))
                                        {
                                            <a class="btn btn-sm btn-outline-secondary" href="@Url.Content(r.UrlVisualizar)">
                                                <i class="bi bi-box-arrow-up-right"></i> Abrir
                                            </a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(r.UrlDownload))
                                        {
                                            <a class="btn btn-sm btn-primary" href="@Url.Content(r.UrlDownload)">
                                                <i class="bi bi-download"></i> Baixar
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
          const $grid = $("#relGrid");
          const $busca = $("#txtBuscaRel");
          let activeCat = "Todos";
          let activePeriod = "any";

          function applyFilters() {
            const q = ($busca.val() || "").toString().trim().toLowerCase();

            const now = new Date();
            let minDate = new Date(0);
            if (activePeriod === "7d")  minDate = new Date(now - 7  * 864e5);
            if (activePeriod === "30d") minDate = new Date(now - 30 * 864e5);
            if (activePeriod === "90d") minDate = new Date(now - 90 * 864e5);

            $grid.children("[data-cat]").each(function() {
              const cat = $(this).data("cat");
              const title = ($(this).data("title") || "").toString();
              const updated = new Date($(this).data("updated"));
              const matchCat = (activeCat === "Todos") || (cat === activeCat);
              const matchText = !q || title.indexOf(q) >= 0;
              const matchDate = updated >= minDate;
              $(this).toggle(matchCat && matchText && matchDate);
            });
          }

          // clique no menu lateral
          $(document).on("click", ".rel-side-link", function(e){
            e.preventDefault();
            $(".rel-side-link").removeClass("active");
            $(this).addClass("active");
            activeCat = $(this).data("cat");
            applyFilters();
          });

          // busca
          $busca.on("input", function(){
            clearTimeout(window._t);
            window._t = setTimeout(applyFilters, 200);
          });

          // período
          $(document).on("click", "[data-period]", function(e){
            e.preventDefault();
            activePeriod = $(this).data("period");
            applyFilters();
          });

          // inicial
          activeCat = $(".rel-side-link.active").data("cat") || "Todos";
          applyFilters();
        })();
    </script>
}
