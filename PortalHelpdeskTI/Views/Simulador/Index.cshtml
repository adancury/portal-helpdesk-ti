@{
    ViewData["Title"] = "Simulador de Prazos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .simulador-prazos {
            --sim-highlight: color-mix(in srgb, var(--accent) 14%, transparent);
        }

        .simulador-prazos .page-shell {
            max-width: 1180px;
            margin: 0 auto;
        }

        .simulador-prazos .tool-header {
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--surface);
            padding: 1.25rem;
            margin-bottom: 1rem;
        }

        .simulador-prazos .tool-kicker {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            color: var(--accent);
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .04em;
            text-transform: uppercase;
            margin-bottom: .35rem;
        }

        .simulador-prazos .tool-header h2 {
            margin: 0;
            color: var(--heading-fg);
            font-weight: 700;
        }

        .simulador-prazos .toolbar-card,
        .simulador-prazos .results-card,
        .simulador-prazos .detail-panel {
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--surface);
        }

        .simulador-prazos .toolbar-card {
            padding: 1rem;
            margin-bottom: 1rem;
        }

        .simulador-prazos label {
            color: var(--label-fg);
            font-weight: 600;
            font-size: .85rem;
        }

        .simulador-prazos .filter-bar {
            display: flex;
            gap: .5rem;
            flex-wrap: wrap;
        }

        .simulador-prazos .filter-btn {
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text);
            border-radius: 6px;
            padding: .35rem .75rem;
            font-size: .85rem;
        }

        .simulador-prazos .filter-btn:hover,
        .simulador-prazos .filter-btn.active {
            border-color: var(--accent);
            background: var(--sim-highlight);
            color: var(--heading-fg);
        }

        .simulador-prazos .stat-chip {
            border: 1px solid var(--border);
            border-radius: 6px;
            background: var(--surface-alt);
            color: var(--muted);
            padding: .55rem .75rem;
            font-size: .85rem;
        }

        .simulador-prazos .stat-chip strong {
            color: var(--heading-fg);
        }

        .simulador-prazos .detail-panel {
            display: none;
            padding: 1rem;
            margin-bottom: 1rem;
            border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
        }

        .simulador-prazos .detail-panel.visible {
            display: block;
        }

        .simulador-prazos .detail-title {
            color: var(--heading-fg);
            font-size: 1.05rem;
            font-weight: 700;
        }

        .simulador-prazos .detail-meta {
            color: var(--muted);
            font-size: .9rem;
        }

        .simulador-prazos .detail-timeline {
            display: flex;
            gap: 0;
            overflow-x: auto;
            padding: 1rem .25rem .25rem;
        }

        .simulador-prazos .timeline-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            min-width: 92px;
        }

        .simulador-prazos .timeline-item:not(:last-child)::after {
            content: "";
            position: absolute;
            top: 16px;
            left: 50%;
            right: -50%;
            height: 2px;
            background: var(--border);
        }

        .simulador-prazos .timeline-dot {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--primary);
            color: var(--primary-contrast);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            position: relative;
            z-index: 1;
            margin-bottom: .45rem;
        }

        .simulador-prazos .timeline-days {
            color: var(--heading-fg);
            font-size: .78rem;
            font-weight: 700;
        }

        .simulador-prazos .timeline-date {
            color: var(--muted);
            font-size: .78rem;
            text-align: center;
        }

        .simulador-prazos .table-responsive {
            border-radius: 8px;
        }

        .simulador-prazos table {
            margin-bottom: 0;
        }

        .simulador-prazos tbody tr {
            cursor: pointer;
        }

        .simulador-prazos tbody tr:hover {
            background: var(--sim-highlight);
        }

        .simulador-prazos .td-code,
        .simulador-prazos .td-avg {
            font-weight: 700;
            color: var(--heading-fg);
            white-space: nowrap;
        }

        .simulador-prazos .td-name {
            min-width: 190px;
        }

        .simulador-prazos .dates-cell {
            display: flex;
            flex-wrap: wrap;
            gap: .35rem;
            min-width: 300px;
        }

        .simulador-prazos .date-tag {
            border: 1px solid var(--border);
            border-radius: 999px;
            background: var(--surface-alt);
            color: var(--text);
            padding: .15rem .5rem;
            font-size: .78rem;
            white-space: nowrap;
        }

        .simulador-prazos .parcelas-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 42px;
            border-radius: 999px;
            padding: .2rem .55rem;
            font-size: .78rem;
            font-weight: 700;
            border: 1px solid transparent;
        }

        .simulador-prazos .p-1x { background: rgba(25, 135, 84, .12); color: #198754; border-color: rgba(25, 135, 84, .25); }
        .simulador-prazos .p-2x { background: rgba(13, 110, 253, .12); color: #0d6efd; border-color: rgba(13, 110, 253, .25); }
        .simulador-prazos .p-3x { background: rgba(255, 193, 7, .16); color: #9a6a00; border-color: rgba(255, 193, 7, .32); }
        .simulador-prazos .p-4x { background: rgba(243, 112, 33, .14); color: var(--accent); border-color: rgba(243, 112, 33, .28); }
        .simulador-prazos .p-5x { background: rgba(220, 53, 69, .12); color: #dc3545; border-color: rgba(220, 53, 69, .25); }
        .simulador-prazos .p-6x,
        .simulador-prazos .p-7x { background: rgba(111, 66, 193, .12); color: #6f42c1; border-color: rgba(111, 66, 193, .25); }

        .simulador-prazos .empty-state {
            display: none;
            text-align: center;
            padding: 3rem 1rem;
            color: var(--muted);
        }
    </style>
}

<div class="simulador-prazos">
    <div class="page-shell">
        <div class="tool-header">
            <div class="tool-kicker">
                <i class="bi bi-calculator"></i>
                Ferramenta Comercial
            </div>
            <div class="d-flex flex-wrap align-items-end justify-content-between gap-2">
                <div>
                    <h2>Simulador de Prazos</h2>
                    <div class="text-muted">Condições de pagamento por data de faturamento e vencimentos.</div>
                </div>
                <a class="btn btn-outline-secondary btn-sm" asp-controller="Inicio" asp-action="Index">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
            </div>
        </div>

        <div class="toolbar-card">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label for="dateFat" class="form-label">Data de Faturamento</label>
                    <input type="date" id="dateFat" class="form-control" />
                </div>
                <div class="col-12 col-md-5">
                    <label for="searchInput" class="form-label">Buscar condição</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchInput" class="form-control" placeholder="Ex.: 30 dias, 28/56 ou código" />
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="d-grid">
                        <button type="button" class="btn btn-outline-secondary" id="clearSearch">
                            <i class="bi bi-eraser"></i> Limpar filtros
                        </button>
                    </div>
                </div>
            </div>

            <div class="filter-bar mt-3" id="filterBar" aria-label="Filtro por quantidade de parcelas">
                <button type="button" class="filter-btn active" data-filter="all">Todas</button>
                <button type="button" class="filter-btn" data-filter="1x">1x</button>
                <button type="button" class="filter-btn" data-filter="2x">2x</button>
                <button type="button" class="filter-btn" data-filter="3x">3x</button>
                <button type="button" class="filter-btn" data-filter="4x">4x</button>
                <button type="button" class="filter-btn" data-filter="5x">5x</button>
                <button type="button" class="filter-btn" data-filter="6x">6x</button>
                <button type="button" class="filter-btn" data-filter="7x+">7x+</button>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3" id="statsRow">
                <div class="stat-chip">Total: <strong id="statTotal">0</strong> condições</div>
                <div class="stat-chip">Exibindo: <strong id="statVisible">0</strong></div>
                <div class="stat-chip">Prazo médio: <strong id="statAvg">-</strong> dias</div>
            </div>
        </div>

        <div id="detailPanel" class="detail-panel">
            <div class="d-flex justify-content-between gap-3">
                <div>
                    <div class="detail-title" id="detailTitle"></div>
                    <div class="detail-meta" id="detailMeta"></div>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm align-self-start" onclick="closeDetail()" aria-label="Fechar detalhe">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="detail-timeline" id="detailTimeline"></div>
        </div>

        <div class="results-card">
            <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
                <h5 class="mb-0">Condições disponíveis</h5>
                <span class="text-muted small" id="resultsCount"></span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Cód.</th>
                            <th>Condição de Pagamento</th>
                            <th>Parcelas</th>
                            <th>Prazo Médio</th>
                            <th>Datas de Vencimento</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
            </div>
            <div id="emptyState" class="empty-state">
                <i class="bi bi-search fs-1 d-block mb-2"></i>
                Nenhuma condição encontrada.
            </div>
        </div>
    </div>
</div>

