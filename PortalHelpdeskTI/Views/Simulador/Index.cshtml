        function addDays(date, days) {
            const d = new Date(date);
            d.setDate(d.getDate() + days);
            return d;
        }

        function formatDate(d) {
            return d.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' });
        }

        function getTodayStr() {
            const now = new Date();
            return now.toISOString().split('T')[0];
        }

        let currentFilter = 'all';
        let currentSearch = '';
        let baseDate = null;

        const dateInput = document.getElementById('dateFat');
        dateInput.value = getTodayStr();
        baseDate = new Date(dateInput.value + 'T12:00:00');
        document.getElementById('statTotal').textContent = rawData.length;

        function getFilteredData() {
            return rawData.filter(row => {
                const [cod, nome, , parcelas] = row;
                const pMatch = currentFilter === 'all'
                    ? true
                    : currentFilter === '7x+'
                        ? parseInt(parcelas, 10) >= 7
                        : parcelas === currentFilter;

                const search = currentSearch.toLowerCase();
                const searchOk = !search
                    || nome.toLowerCase().includes(search)
                    || String(cod).includes(search)
                    || parcelas.includes(search);

                return pMatch && searchOk;
            });
        }

        function render() {
            const data = getFilteredData();
            const tbody = document.getElementById('tableBody');
            const empty = document.getElementById('emptyState');
            document.getElementById('resultsCount').textContent = `${data.length} resultado(s)`;
            document.getElementById('statVisible').textContent = data.length;

            if (data.length > 0) {
                const avgAll = data.reduce((s, r) => s + r[2], 0) / data.length;
                document.getElementById('statAvg').textContent = avgAll.toFixed(1);
            } else {
                document.getElementById('statAvg').textContent = '-';
            }

            if (data.length === 0) {
                tbody.innerHTML = '';
                empty.style.display = 'block';
                return;
            }

            empty.style.display = 'none';
            tbody.innerHTML = data.map(row => {
                const [cod, nome, avg, parcelas, prazos] = row;
                const px = parseInt(parcelas, 10);
                const pClass = px >= 7 ? 'p-7x' : `p-${px}x`;
                const datesHtml = prazos.map((d, i) => {
                    const venc = baseDate ? formatDate(addDays(baseDate, d)) : `+${d}d`;
                    return `<span class="date-tag">${i + 1}º ${venc}</span>`;
                }).join('');

                return `<tr onclick="showDetail(${cod})">
                    <td class="td-code">${cod}</td>
                    <td class="td-name">${nome}</td>
                    <td><span class="parcelas-badge ${pClass}">${parcelas}</span></td>
                    <td class="td-avg">${avg.toFixed(1)}d</td>
                    <td><div class="dates-cell">${datesHtml}</div></td>
                </tr>`;
            }).join('');
        }

        function showDetail(cod) {
            const row = rawData.find(r => r[0] === cod);
            if (!row) return;

            const [c, nome, avg, parcelas, prazos] = row;
            document.getElementById('detailTitle').textContent = `Cód. ${c} - ${nome}`;
            document.getElementById('detailMeta').textContent = `${parcelas} | Prazo médio: ${avg.toFixed(1)} dias`;

            document.getElementById('detailTimeline').innerHTML = prazos.map((d, i) => {
                const venc = baseDate ? formatDate(addDays(baseDate, d)) : `+${d}d`;
                return `<div class="timeline-item">
                    <div class="timeline-dot">${i + 1}</div>
                    <div class="timeline-days">+${d}d</div>
                    <div class="timeline-date">${venc}</div>
                </div>`;
            }).join('');

            const panel = document.getElementById('detailPanel');
            panel.classList.add('visible');
            panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function closeDetail() {
            document.getElementById('detailPanel').classList.remove('visible');
        }

        dateInput.addEventListener('change', () => {
            baseDate = dateInput.value ? new Date(dateInput.value + 'T12:00:00') : null;
            render();
        });

        document.getElementById('searchInput').addEventListener('input', e => {
            currentSearch = e.target.value;
            render();
        });

        document.getElementById('filterBar').addEventListener('click', e => {
            const btn = e.target.closest('.filter-btn');
            if (!btn) return;
            document.querySelectorAll('.simulador-prazos .filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentFilter = btn.dataset.filter;
            render();
        });

        document.getElementById('clearSearch').addEventListener('click', () => {
            currentFilter = 'all';
            currentSearch = '';
            document.getElementById('searchInput').value = '';
            document.querySelectorAll('.simulador-prazos .filter-btn').forEach(b => b.classList.remove('active'));
            document.querySelector('.simulador-prazos .filter-btn[data-filter="all"]').classList.add('active');
            closeDetail();
            render();
        });

        render();
    </script>
}
