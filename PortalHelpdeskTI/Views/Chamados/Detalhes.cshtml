@using System.IO
@model Chamado
@using PortalHelpdeskTI.Models
@using System.Net
@using System.Text.RegularExpressions

@{
    ViewData["Title"] = "Detalhes do Chamado";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var perfil = Context.Session.GetString("Perfil");
    var isSolicitante = (perfil == "Usuario" || perfil == "Usuário"); // cobre acento tb

    bool podeReabrir = Model.Status == "Concluído"
                       && Model.DataConclusao != null
                       && (DateTime.Now - Model.DataConclusao.Value).TotalHours <= 24;

    var jaAvaliado = (ViewBag.JaAvaliado as bool?) ?? false; // vem do Controller

    // Se quiser liberar o botão IMEDIATAMENTE após concluir, deixe SEM !podeReabrir
    var podeAvaliar = isSolicitante
                      && string.Equals(Model.Status, "Concluído", StringComparison.OrdinalIgnoreCase)
                      && !jaAvaliado;

    // Se quiser liberar só após expirar a reabertura:
    // var podeAvaliar = isSolicitante
    //                   && string.Equals(Model.Status, "Concluído", StringComparison.OrdinalIgnoreCase)
    //                   && !podeReabrir
    //                   && !jaAvaliado;
}



<link rel="stylesheet" href="/lib/bootstrap/css/bootstrap.min.css" />
<link rel="stylesheet" href="/css/atender.css" />
<link rel="stylesheet" href="/css/site.css" />
<div id="overlay-bloqueio">
    <div class="overlay-conteudo">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Carregando...</span>
        </div>
        <p>Atualizando chamado, aguarde...</p>
    </div>
</div>
<div class="container pt-5">
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div class="toast align-items-center text-bg-success border-0 show" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        @TempData["MensagemSucesso"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
                </div>
            </div>
        </div>
    }

    <h2>#@Model.Id - @Model.Titulo</h2>
    <div class="mb-2">
        <span class="badge @GetStatusBadgeClass(Model.Status)" style="font-size: 1rem;">
            @Model.Status
        </span>
    </div>

    <div class="descricao-chamado mb-4">
        @{
            var raw = Model.Descricao ?? string.Empty;
            // Remove somente espaços/tabs no INÍCIO do texto (não mexe nas quebras)
            var desc = Regex.Replace(raw, @"^[ \t]+", "");
        }
        <div style="white-space: pre-line;">@desc</div>
    </div>

    @if (Model.Status == "Concluído")
    {
        <div class="alert alert-success border border-success shadow-sm p-4 mb-4">
            <h5 class="mb-3">
                <i class="bi bi-check-circle-fill me-2"></i>
                Solução Aplicada
            </h5>
            <p class="mb-0" style="white-space: pre-line;">
                @(string.IsNullOrWhiteSpace(Model.Solucao) ? "Solução não informada." : Model.Solucao)
            </p>
        </div>
    }
    @if (podeAvaliar)
    {
        <div class="mb-4">
            <a asp-controller="Chamados" asp-action="Avaliar" asp-route-id="@Model.Id"
               class="btn btn-like-alert-warning w-100 py-3">
                <i class="bi bi-bar-chart"></i> Avaliar atendimento
            </a>
        </div>
    }



    <div class="row align-items-stretch">
        <!-- Coluna Esquerda -->
        <div class="col-md-6 h-100">
            <div class="atender-container h-100">

                <div class="info-tags mb-3">
                    <span class="badge @GetPrioridadeBadgeClass(Model.Prioridade)">
                        Prioridade: @Model.Prioridade
                    </span>
                    <span class="tag-data badge bg-info text-dark">
                        Abertura: @Model.DataAbertura.ToString("dd/MM/yyyy HH:mm")
                    </span>
                </div>

                @if (perfil == "Técnico" || perfil == "Tecnico")
                {
                    <p><strong>Técnico Responsável:</strong> @(Model.Tecnico?.Nome ?? "Não atribuído")</p>

                    @if (Model.Status == "Concluído" && !jaAvaliado && !Model.AvaliacaoLembreteEnviado)
                    {
                        <form asp-action="EnviarLembreteAvaliacao" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-like-alert-warning border border-warning mb-2">
                                <i class="bi bi-envelope"></i> Enviar lembrete de avaliação
                            </button>
                        </form>
                    }

                    <div class="mt-3">
                        <a href="/Chamados/Index" class="btn btn-secondary w-100">Voltar</a>
                    </div>
                }
                else if (perfil == "Usuario")
                {
                    @if (podeReabrir)
                    {
                        <h4 class="mt-2">Reabrir Chamado</h4>
                        <form method="post" action="/Chamados/ReabrirChamado">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="mb-2">
                                <label for="motivo">Motivo da Reabertura</label>
                                <textarea class="form-control" id="motivo" name="motivo" rows="3" required
                                  placeholder="Descreva o motivo da reabertura..."></textarea>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-warning">
                                    <i class="bi bi-arrow-repeat"></i> Reabrir Chamado
                                </button>
                                <a href="/Chamados/Index" class="btn btn-secondary">Voltar</a>
                            </div>
                        </form>
                    }
                    else if (Model.Status == "Concluído")
                    {
                        <div class="alert alert-warning border border-warning shadow-sm p-4 mt-4 d-flex align-items-start">
                            <i class="bi bi-clock-history me-3" style="font-size: 1.8rem;"></i>
                            <div>
                                <h5 class="mb-2">Prazo para Reabertura Expirado</h5>
                                <p class="mb-0">
                                    O prazo de 24 horas para reabrir este chamado foi encerrado.
                                    Caso ainda precise de suporte, por favor, abra um novo chamado.
                                </p>
                            </div>
                        </div>

                        <div class="mt-3">
                            <a href="/Chamados/Index" class="btn btn-secondary">Voltar</a>
                        </div>
                    }
                    else
                    {
                        // EXIBE O FORMULÁRIO DE INTERAÇÃO NORMAL AQUI
                        <h4 class="mt-2">Adicionar Interação</h4>
                        <form id="formInteracao" method="post" action="/Chamados/AdicionarInteracao" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ChamadoId" value="@Model.Id" />
                            <div class="mb-2">
                                <label for="mensagem">Mensagem</label>
                                <textarea class="form-control" id="mensagem" name="mensagem" rows="3" required placeholder="Escreva sua dúvida ou comentário..."></textarea>
                            </div>
                            <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
                                <label for="anexo" class="form-label mb-0 me-2">Anexo: </label>

                                <input type="file"
                                       class="form-control form-control-sm w-auto"
                                       id="anexo" name="anexo"
                                       style="max-width: 320px;" />

                                @if (Model.Anexos != null && Model.Anexos.Count > 0)
                                {
                                    <button type="button" class="btn-anexo" data-bs-toggle="modal" data-bs-target="#modalAnexos">
                                        <img src="/images/anexo_branco.png" alt="Anexos" style="height: 20px;" />
                                    </button>
                                    //<span class="text-muted" style="font-size:.9rem;">Anexos do chamado</span>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:.9rem;">🔒 Nenhum anexo disponível</span>
                                }
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send"></i> Enviar Interação
                                </button>
                                <a href="/Chamados/Index" class="btn btn-secondary">Voltar</a>
                            </div>
                        </form>
                    }
                }
            </div>
        </div>

        <!-- Coluna Direita - Histórico -->
        <div class="col-md-6 h-100">
            <div class="atender-container h-100">
                <h3>Histórico de Interações</h3>
                @if (Model.Interacoes != null && Model.Interacoes.Any())
                {
                    <div class="historico-interacoes">
                        @foreach (var i in Model.Interacoes.OrderByDescending(x => x.Data))
                        {
                            var isTecnico = i.Usuario?.Perfil == "Tecnico" || i.Usuario?.Perfil == "Técnico";
                            <div class="chat-bubble @(isTecnico ? "tecnico" : "usuario")">
                                <div class="chat-message">@i.Mensagem</div>

                                @if (i.Anexos != null && i.Anexos.Any())
                                {
                                    <ul class="list-group list-group-flush mt-1">
                                        @foreach (var anexo in i.Anexos)
                                        {
                                            <li class="list-group-item p-1">
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-paperclip me-1"></i>
                                                    <span class="me-2">@anexo.NomeOriginal</span>
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-secondary p-1 visualizar-anexo"
                                                            data-anexo="/Chamados/DownloadAnexo?chamadoId=@Model.Id&nomeArquivo=@WebUtility.UrlEncode(System.IO.Path.GetFileName(anexo.CaminhoArquivo))"
                                                            data-nome="@anexo.NomeOriginal"
                                                            title="Visualizar Anexo">
                                                        <i class="bi bi-eye"></i>
                                                    </button>

                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }

                                <div class="chat-meta">@i.Data.ToString("dd/MM/yyyy HH:mm") - @i.Usuario?.Nome</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p>Sem interações ainda.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Toast para o popup -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="toastReaberto" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                Chamado reaberto com sucesso!
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
        </div>
    </div>
</div>
<div class="modal fade" id="modalAnexos" tabindex="-1" aria-labelledby="modalAnexosLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content shadow-lg rounded">
            <div class="modal-header bg-light">
                <h5 class="modal-title" id="modalAnexosLabel">Anexos do Chamado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                @if (Model.Anexos != null && Model.Anexos.Count > 0)
                {
                        <div class="list-group">
                            @foreach (var anexo in Model.Anexos)
                            {
                            <a href="/Chamados/DownloadAnexo?chamadoId=@Model.Id&nomeArquivo=@WebUtility.UrlEncode(System.IO.Path.GetFileName(anexo.CaminhoArquivo))"
                                       target="_blank"
                                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <img src="/images/anexo.png" alt="Anexo" style="height: 20px; margin-right: 8px;" />
                                            <span>@anexo.NomeOriginal</span>
                                        </div>
                                        <small class="text-muted">Abrir</small>
                                    </a>
                            }
                        </div>
                }
                else
                {
                        <div class="alert alert-info mb-0">Nenhum anexo enviado.</div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="anexoModal" tabindex="-1" aria-labelledby="anexoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="anexoModalLabel">Visualizar Anexo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body text-center">
                <img id="anexoImage" src="" class="img-fluid d-none" style="max-height: 500px; object-fit: contain;" />
                <iframe id="anexoFrame" src=""
                        style="max-width: 100%; width: 100%; max-height: 500px; height: 500px; border: none;"
                        class="d-none"></iframe>
            </div>
        </div>
    </div>
</div>
<script>
        document.querySelectorAll('.visualizar-anexo').forEach(button => {
        button.addEventListener('click', function () {
            const anexoUrl = this.getAttribute('data-anexo');
            const nome = this.getAttribute('data-nome');

            // Definir as extensões suportadas
            const extensoesImagem = ['.jpg', '.jpeg', '.png', '.gif'];
            const extensoesVideo = ['.mp4'];
            const extensoesDocumento = ['.pdf'];  // PDF é agora tratado separadamente
            const ext = anexoUrl.substring(anexoUrl.lastIndexOf('.')).toLowerCase();

            const modal = new bootstrap.Modal(document.getElementById('anexoModal'));
            const modalTitle = document.querySelector('#anexoModal .modal-title');
            const modalBody = document.querySelector('#anexoModal .modal-body');
            const img = document.getElementById('anexoImage');
            const frame = document.getElementById('anexoFrame');

            // Resetar a visualização do modal
            modalTitle.textContent = '';
            img.classList.add('d-none');
            frame.classList.add('d-none');
            img.src = '';
            frame.src = '';

            // Se for imagem, mostrar no modal
            if (extensoesImagem.includes(ext)) {
                modalTitle.textContent = 'Visualizar Anexo - ' + nome;
                img.src = anexoUrl;
                img.classList.remove('d-none');
                modal.show();
            }
            // Se for vídeo ou documento (PDF), abrir no iframe ou nova aba
            else if (extensoesVideo.includes(ext)) {
                modalTitle.textContent = 'Visualizar Anexo - ' + nome;
                frame.src = anexoUrl;
                frame.classList.remove('d-none');
                modal.show();
            } else if (extensoesDocumento.includes(ext)) {
                // Para PDFs, abrir em uma nova aba (não mostrar modal)
                window.open(anexoUrl, '_blank');
            } else {
                // Para outros tipos de arquivo, faz o download e avisa o usuário
                window.open(anexoUrl, '_blank');
                alert("O download do anexo foi iniciado. Este tipo de arquivo não pode ser visualizado diretamente.");
            }
        });
    });

    document.getElementById('anexoModal').addEventListener('hidden.bs.modal', function () {
        document.getElementById('anexoImage').src = '';
        document.getElementById('anexoFrame').src = '';
    });

</script>
<script>
    const formInteracao = document.getElementById('formInteracao');
    if (formInteracao) {
      formInteracao.addEventListener('submit', function (e) {
        const mensagem = document.getElementById('mensagem');
        if (!mensagem.value.trim()) {
          e.preventDefault();
          alert("Por favor, preencha o campo de interação antes de atualizar o chamado.");
          mensagem.focus();
        } else {
          document.getElementById('overlay-bloqueio').style.display = 'flex';
        }
      });
    }
</script>
<script>
    function mostrarPopupReaberto() {
        var motivo = document.getElementById('motivo').value.trim();
        if (!motivo) {
            alert("Por favor, informe o motivo da reabertura.");
            return;
        }

        var toastEl = document.getElementById('toastReaberto');
        var toast = new bootstrap.Toast(toastEl);
        toast.show();
    }

    const formInteracao = document.getElementById('formInteracao');
    if (formInteracao) {
      formInteracao.addEventListener('submit', function (e) {
        const mensagem = document.getElementById('mensagem');
        if (!mensagem.value.trim()) {
          e.preventDefault();
          alert("Por favor, preencha o campo de interação antes de atualizar o chamado.");
          mensagem.focus();
        } else {
          document.getElementById('overlay-bloqueio').style.display = 'flex';
        }
      });
    }
</script>
@functions {
    public string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            //"Aberto" => "bg-secondary",
            "Aberto" => "bg-info text-dark",
            "Em Atendimento" => "bg-warning text-dark",
            "Aguardando" => "bg-info text-dark",
            "Concluído" => "bg-success",
            _ => "bg-light text-dark"
        };
    }

    public string GetPrioridadeBadgeClass(string prioridade)
    {
        return prioridade switch
        {
            "Alta" => "bg-danger",
            "Crítica" => "bg-danger",
            "Média" => "bg-warning text-dark",
            "Baixa" => "bg-info text-dark",
            _ => "bg-secondary"
        };
    }
}
