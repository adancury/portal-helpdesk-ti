@model IEnumerable<PortalHelpdeskTI.Models.GridTecnicoItemVM>
@using PortalHelpdeskTI.Helpers

@{
    ViewData["Title"] = "Painel Técnico";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var statusSelecionados = ViewBag.StatusSelecionados as List<string> ?? new List<string>();
    var hoje = DateTime.Today;
    var de = new DateTime(hoje.Year, hoje.Month, 1);
    var ate = de.AddMonths(1).AddDays(-1);
    var totalChamados = Model?.Count() ?? 0;
}

<link rel="stylesheet" href="~/css/tecnico-painel.css" />

<div class="container mt-4 tecnico-page">
    <div class="tecnico-header d-flex align-items-center justify-content-between mb-3">
        <h2 class="mb-0">Painel Técnico</h2>
    </div>

    @*
    <!-- KPIs -->
    <div class="row g-2 mb-3">
        <div class="col-12 col-md-3">
            <div class="card kpi-card kpi-total h-100">
                <div class="card-body py-2">
                    <div class="small text-muted">
                        <i class="bi bi-plus-lg me-1"></i>
                        Total de Chamados
                    </div>
                    <div class="fs-4 fw-bold" id="kpi-total">0</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-3">
            <div class="card kpi-card kpi-andamento h-100">
                <div class="card-body py-2">
                    <div class="small text-muted">
                        <i class="bi bi-hourglass me-1"></i>
                        Em andamento
                    </div>
                    <div class="fs-4 fw-bold" id="kpi-andamento">0</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-3">
            <div class="card kpi-card kpi-resolvidos h-100">
                <div class="card-body py-2">
                    <div class="small text-muted">
                        <i class="bi bi-check2 me-1"></i>
                        Resolvidos
                    </div>
                    <div class="fs-4 fw-bold" id="kpi-resolvidos">0</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-3">
            <div class="card kpi-card kpi-urgentes h-100">
                <div class="card-body py-2">
                    <div class="small text-muted">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Urgentes
                    </div>
                    <div class="fs-4 fw-bold" id="kpi-urgentes">0</div>
                </div>
            </div>
        </div>
    </div>
    *@
    <!-- Indicadores do mês -->
    <!-- Indicadores do mês -->
    <div class="tecnico-indicadores d-flex align-items-center justify-content-between mb-2">
        <div class="card mb-3 w-100" id="cards-indicadores-wrapper"
             data-de="@de.ToString("yyyy-MM-dd")"
             data-ate="@ate.ToString("yyyy-MM-dd")">

            <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                <strong>Indicadores do mês</strong>

                <div class="d-flex align-items-center gap-2">
                    <!-- Botão gaveta -->
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm kpi-toggle"
                            id="btnToggleKpis"
                            aria-expanded="true"
                            aria-controls="kpiDrawer"
                            title="Recolher/Expandir indicadores">
                        <span class="me-1" id="kpiToggleText">Recolher</span>
                        <i class="bi bi-chevron-up" id="kpiToggleIcon"></i>
                    </button>

                    <!-- Escopo -->
                    <div class="btn-group btn-group-sm" role="group" aria-label="Escopo">
                        <button type="button" class="btn btn-outline-secondary active" data-scope="meu">Meu</button>
                        <button type="button" class="btn btn-outline-secondary" data-scope="time">Time</button>
                    </div>
                </div>
            </div>

            <!-- Gaveta -->
            <div id="kpiDrawer" class="kpi-drawer is-open">
                <div class="card-body">
                    <div class="row g-2" id="cards-indicadores">
                        <!-- SLA -->
                        <div class="col-6 col-lg-3">
                            <div class="card kpi-card h-100 border" data-kpi-card="sla-dentro">
                                <div class="card-body py-2">
                                    <div class="small text-muted">Dentro do SLA</div>
                                    <div class="fs-4 fw-bold" data-kpi="FechadosDentroSla">-</div>
                                    <div class="small text-muted"><span data-kpi="PercDentroSla">-</span>%</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-lg-3">
                            <div class="card kpi-card h-100 kpi-sla-fora">
                                <div class="card-body py-2">
                                    <div class="small text-muted">Fora do SLA</div>

                                    <!-- TOTAL (abertos + fechados) -->
                                    <div class="fs-4 fw-bold" data-kpi="ForaSlaTotal">-</div>

                                    <div class="small text-muted">
                                        Fechados: <span data-kpi="FechadosForaSla">-</span>
                                    </div>
                                    <div class="small text-muted">
                                        Em aberto: <span data-kpi="EmAbertoForaSla">-</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Qualidade -->
                        <div class="col-6 col-lg-3">
                            <div class="card kpi-card h-100">
                                <div class="card-body py-2">
                                    <div class="small text-muted">Reabertos</div>
                                    <div class="fs-4 fw-bold" data-kpi="Reabertos">-</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-lg-3">
                            <div class="card kpi-card h-100">
                                <div class="card-body py-2">
                                    <div class="small text-muted">Satisfação (média)</div>
                                    <div class="fs-4 fw-bold"><span data-kpi="SatisfacaoMedia">-</span></div>
                                    <div class="small text-muted"><span data-kpi="TotalAvaliacoes">-</span> avaliações</div>
                                </div>
                            </div>
                        </div>

                        <!-- Operacional -->
                        <div class="col-6 col-lg-3">
                            <div class="card kpi-card h-100">
                                <div class="card-body py-2">
                                    <div class="small text-muted">Abertos</div>
                                    <div class="fs-4 fw-bold" data-kpi="Abertos">-</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-lg-3">
                            <div class="card kpi-card h-100">
                                <div class="card-body py-2">
                                    <div class="small text-muted">Em Atendimento</div>
                                    <div class="fs-4 fw-bold" data-kpi="EmAtendimento">-</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-lg-3">
                            <div class="card kpi-card h-100">
                                <div class="card-body py-2">
                                    <div class="small text-muted">Fechados hoje</div>
                                    <div class="fs-4 fw-bold" data-kpi="FechadosHoje">-</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-lg-3">
                            <div class="card kpi-card h-100">
                                <div class="card-body py-2">
                                    <div class="small text-muted">Tempo médio de atendimento</div>
                                    <div class="fs-4 fw-bold" data-kpi="TempoMedioResolucaoFmt">-</div>
                                </div>
                            </div>
                        </div>
                    </div> <!-- /#cards-indicadores -->
                </div> <!-- /.card-body -->
            </div> <!-- /#kpiDrawer -->
        </div> <!-- /#cards-indicadores-wrapper -->
    </div>
    <style>
        body.tecnico-body-lock {
            overflow: hidden;
        }

        .tecnico-page {
            height: calc(100vh - 150px);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .tecnico-header,
        .tecnico-indicadores {
            flex: 0 0 auto;
        }

        .tecnico-grid-card {
            flex: 1 1 auto;
            min-height: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid var(--bs-border-color);
            box-shadow: 0 .15rem .4rem rgba(0,0,0,.06);
        }

        .tecnico-grid-card .card-header {
            flex: 0 0 auto;
            background: var(--bs-card-cap-bg);
            border-bottom: 1px solid var(--bs-border-color);
        }

        .tecnico-total {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .3rem .65rem;
            border-radius: .5rem;
            background: #f0f6ff;
            color: #004A80;
            border: 1px solid rgba(0, 74, 128, .18);
            font-weight: 700;
            white-space: nowrap;
        }

        .tecnico-grid-scroll {
            flex: 1 1 auto;
            min-height: 0;
            overflow: auto;
        }

        #grid-container {
            flex: 1 1 auto;
            min-height: 0;
            display: flex;
            flex-direction: column;
        }

        #grid-wrapper {
            flex: 1 1 auto;
            min-height: 0;
            display: flex !important;
            flex-direction: column;
        }

        #tabela-painel {
            min-width: 1080px;
        }

        #tabela-painel th {
            position: sticky;
            top: 0;
            z-index: 2;
            background-color: #004a80 !important;
            color: #fff;
            white-space: nowrap;
        }

        [data-bs-theme="dark"] .tecnico-total {
            background: #0b213e;
            color: #e7eef7;
            border-color: rgba(77, 171, 247, .35);
        }

        @@media (max-width: 767.98px) {
            .tecnico-page {
                height: calc(100vh - 126px);
            }
        }

        /* === Painel Técnico: linha clicável + truncamento de título === */
        #tabela-painel tbody tr.chamado-row-click {
            cursor: pointer;
        }

            #tabela-painel tbody tr.chamado-row-click:hover {
                filter: brightness(0.98);
            }

        /* Limita o tamanho da coluna Título e aplica reticências */
        #tabela-painel th.col-titulo,
        #tabela-painel td.col-titulo {
            width: 420px;
            max-width: 420px;
        }

            #tabela-painel td.col-titulo .titulo-text {
                display: inline-block;
                max-width: 380px; /* deixa espaço para a bolinha */
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                vertical-align: middle;
            }
    </style>

    <!-- Grid -->
    <div id="grid-container">
        <div class="tecnico-grid-card card">
            <div class="card-header d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <strong>Chamados</strong>
                <span class="tecnico-total">
                    <i class="bi bi-list-task"></i>
                    @totalChamados chamados listados
                </span>
            </div>
            <div id="grid-wrapper">
                <div class="tecnico-grid-scroll">
                    @await Html.PartialAsync("_GridTecnico", Model)
                </div>
            </div>

            <div id="filtroStatusDropdown" class="dropdown-filtro-status d-none">
                <form id="filtroStatusForm">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="statusSelecionados" value="Aberto" id="status-Aberto">
                        <label class="form-check-label" for="status-Aberto">Aberto</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="statusSelecionados" value="Em Atendimento" id="status-EmAtendimento">
                        <label class="form-check-label" for="status-EmAtendimento">Em Atendimento</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="statusSelecionados" value="Aguardando" id="status-Aguardando">
                        <label class="form-check-label" for="status-Aguardando">Aguardando</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="statusSelecionados" value="Concluído" id="status-Concluído">
                        <label class="form-check-label" for="status-Concluído">Concluído</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="statusSelecionados" value="Resposta do Usuário" id="status-RespostaUsuario">
                        <label class="form-check-label" for="status-RespostaUsuario">Resposta do Usuário</label>
                    </div>
                    <button type="button" class="btn btn-sm btn-primary mt-2" onclick="aplicarFiltroStatus()">Aplicar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<audio id="notificacaoAudio">
    <source src="/sounds/alert.mp3" type="audio/mpeg">
    Seu navegador não suporta áudio.
</audio>

<div class="toast align-items-center text-bg-info border-0" role="alert" aria-live="assertive" aria-atomic="true"
     id="toastInteracao" style="position: fixed; bottom: 1rem; right: 1rem; z-index: 2000; display: none;">
    <div class="d-flex">
        <div class="toast-body">🚀 Novos chamados aguardando...</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
</div>

@section Scripts {

    <script>
        document.body.classList.add('tecnico-body-lock');
    </script>

    <script>
        // ======== Grid destaque =========
        let chamadosDestacados = [];

        function destacarLinha(id) {
            const row = document.querySelector(`#tabela-painel tr[data-id="${id}"]`);
            if (row) {
                row.classList.add('table-warning');
                const botao = row.querySelector('.botao-visualizar');
                if (botao && !botao.querySelector('.bolinha-notificacao')) {
                    const span = document.createElement('span');
                    span.className = 'bolinha-notificacao position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle';
                    span.innerHTML = '<span class="visually-hidden">Novo</span>';
                    botao.appendChild(span);
                }
            }
        }

        function atualizarGridComDestaque() {
            const selectedStatus = Array.from(document.querySelectorAll('input[name="statusSelecionados"]:checked'))
                .map(cb => `statusSelecionados=${encodeURIComponent(cb.value)}`).join('&');

            const linhasDestacadasAntes = Array.from(document.querySelectorAll('#tabela-painel tr.table-warning'))
                .map(row => parseInt(row.getAttribute('data-id')));

            fetch('/Chamados/GridTecnicoParcial?' + selectedStatus)
                .then(response => response.text())
                .then(html => {
                    const temp = document.createElement('div');
                    temp.innerHTML = html;
                    const novoTbody = temp.querySelector('tbody');

                    if (novoTbody) {
                        const tbodyAntigo = document.querySelector('#corpo-tabela-tecnico');
                        if (tbodyAntigo) {
                            tbodyAntigo.innerHTML = novoTbody.innerHTML;
                            document.getElementById("grid-wrapper").style.display = "block";

                            linhasDestacadasAntes.forEach(id => {
                                destacarLinha(id);
                                if (!chamadosDestacados.includes(id)) chamadosDestacados.push(id);
                            });
                        }
                    }

                    fetch('/Chamados/ChamadosComInteracaoUsuario')
                        .then(response => response.json())
                        .then(ids => {
                            ids.forEach(id => {
                                if (!chamadosDestacados.includes(id)) {
                                    destacarLinha(id);
                                    chamadosDestacados.push(id);
                                }
                            });
                        });
                })
                .catch(err => console.error('Erro ao atualizar grid:', err));
        }

        window.addEventListener('load', function () {
            const linhasDestacadas = document.querySelectorAll('#tabela-painel tr.table-warning');
            linhasDestacadas.forEach(linha => {
                const id = parseInt(linha.getAttribute('data-id'));
                if (!chamadosDestacados.includes(id)) chamadosDestacados.push(id);
            });

            atualizarGridComDestaque();
            setInterval(atualizarGridComDestaque, 60000);
        });
    </script>

    <script>
        // ======== Filtro status dropdown =========
        function toggleFiltroStatusDropdown(event) {
            event.stopPropagation();

            const dropdown = document.getElementById('filtroStatusDropdown');
            const botao = event.currentTarget;

            if (dropdown.classList.contains('d-none')) {
                const rect = botao.getBoundingClientRect();
                dropdown.style.top = `${rect.bottom + window.scrollY}px`;
                dropdown.style.left = `${rect.left + window.scrollX}px`;
                dropdown.classList.remove('d-none');
            } else {
                dropdown.classList.add('d-none');
            }

            document.addEventListener('click', function fecharDropdown(e) {
                if (!dropdown.contains(e.target) && !botao.contains(e.target)) {
                    dropdown.classList.add('d-none');
                    document.removeEventListener('click', fecharDropdown);
                }
            });
        }

        function aplicarFiltroStatus() {
            const dropdown = document.getElementById('filtroStatusDropdown');

            const params = new URLSearchParams();
            document
                .querySelectorAll('#filtroStatusForm input[name="statusSelecionados"]:checked')
                .forEach(cb => params.append('statusSelecionados', cb.value));

            localStorage.setItem('filtrosStatusSelecionados',
                JSON.stringify(Array.from(params.getAll('statusSelecionados'))));

            fetch('/Chamados/GridTecnicoParcial?' + params.toString(), { method: 'GET' })
                .then(r => r.text())
                .then(html => {
                    const temp = document.createElement('div');
                    temp.innerHTML = html;
                    const novoTbody = temp.querySelector('tbody');
                    const tbodyAntigo = document.querySelector('#corpo-tabela-tecnico');
                    if (novoTbody && tbodyAntigo) {
                        tbodyAntigo.innerHTML = novoTbody.innerHTML;
                        document.getElementById('grid-wrapper').style.display = 'block';
                    }
                })
                .catch(console.error)
                .finally(() => dropdown.classList.add('d-none'));
        }

        document.addEventListener('DOMContentLoaded', function () {
            const filtrosSalvos = localStorage.getItem('filtrosStatusSelecionados');
            if (filtrosSalvos) {
                const filtros = JSON.parse(filtrosSalvos);
                filtros.forEach(status => {
                    const checkbox = document.querySelector(`input[name="statusSelecionados"][value="${status}"]`);
                    if (checkbox) checkbox.checked = true;
                });
            } else {
                document
                    .querySelectorAll('#filtroStatusForm input[name="statusSelecionados"]')
                    .forEach(cb => cb.checked = cb.value !== 'Concluído');
            }
        });
    </script>

    <script>
        // ======== KPIs antigos =========
        function loadKpis(){
            $.getJSON('/Chamados/ResumoTecnico', function(r){
                if(!r) return;
                $('#kpi-total').text(r.total ?? 0);
                $('#kpi-andamento').text(r.andamento ?? 0);
                $('#kpi-resolvidos').text(r.resolvidos ?? 0);
                $('#kpi-urgentes').text(r.urgentes ?? 0);
            });
        }
        (function(){
            loadKpis();
            setInterval(loadKpis, 30000);
        })();
    </script>

    <script>
        (function () {
          const wrap = document.getElementById('cards-indicadores-wrapper');
          if (!wrap) return;

          let scope = 'meu';

          function setActiveScope(btn) {
            wrap.querySelectorAll('[data-scope]').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            scope = btn.getAttribute('data-scope');
            loadIndicadores();
          }

          wrap.querySelectorAll('[data-scope]').forEach(btn => {
            btn.addEventListener('click', () => setActiveScope(btn));
          });

          function setSlaCardColor(percDentro) {
            const card = wrap.querySelector('[data-kpi-card="sla-dentro"]');
            if (!card) return;

            card.classList.remove('border-success', 'border-warning', 'border-danger');
            if (percDentro >= 90) card.classList.add('border-success');
            else if (percDentro >= 80) card.classList.add('border-warning');
            else card.classList.add('border-danger');
          }

            function getVal(obj, key) {
              if (!obj) return undefined;

              if (obj[key] !== undefined) return obj[key];

              const camel = key.charAt(0).toLowerCase() + key.slice(1);
              if (obj[camel] !== undefined) return obj[camel];

              return undefined;
            }


          function unwrapPayload(data) {
            // tenta achar onde estão "meu/time"
            if (!data) return data;

            // direto
            if (data.meu || data.time || data.Meu || data.Time) return data;

            // camadas comuns
            const candidates = [data.data, data.result, data.value, data.vm, data.payload];
            for (const c of candidates) {
              if (c && (c.meu || c.time || c.Meu || c.Time)) return c;
            }

            return data; // fallback
          }

          function getScopeObj(data) {
            const root = unwrapPayload(data);

            const meu = root?.meu ?? root?.Meu;
            const time = root?.time ?? root?.Time;

            return (scope === 'time') ? time : meu;
          }

          function fillCards(raw) {
            const data = unwrapPayload(raw);
            const src = getScopeObj(data);

            // log útil para depurar só uma vez
            console.log('[IndicadoresPainelTecnico] payload:', raw);
            console.log('[IndicadoresPainelTecnico] scope:', scope, 'src:', src);

            if (!src) return;

            wrap.querySelectorAll('[data-kpi]').forEach(el => {
              const key = el.getAttribute('data-kpi');
              let val = getVal(src, key);

              if (val === null || val === undefined) {
                  val = '-';
                } else if (typeof val === 'number') {
                  val = val.toString();
                }


              if (key === 'SatisfacaoMedia' && val !== '-') val = Number(val).toFixed(2);
              if (key === 'PercDentroSla' && val !== '-') val = Number(val).toFixed(2);

              el.textContent = val;
            });

            const percVal = getVal(src, 'PercDentroSla');
            const perc = Number(percVal ?? 0);
            setSlaCardColor(perc);
          }

          async function loadIndicadores() {
            const de = wrap.getAttribute('data-de');
            const ate = wrap.getAttribute('data-ate');

            try {
              const r = await fetch(`/Chamados/IndicadoresPainelTecnico?de=${de}&ate=${ate}`, {
                headers: { 'Accept': 'application/json' }
              });

              // se vier HTML (ex.: redirect/login), mostra no console
              const ct = r.headers.get('content-type') || '';
              if (!ct.includes('application/json')) {
                const txt = await r.text();
                console.error('IndicadoresPainelTecnico não retornou JSON. Content-Type:', ct);
                console.error('Resposta (início):', txt.substring(0, 400));
                return;
              }

              const data = await r.json();
              fillCards(data);
            } catch (e) {
              console.error('Falha ao carregar indicadores:', e);
            }
          }

          loadIndicadores();
          setInterval(loadIndicadores, 30000);
        })();
    </script>
    <script>
        (function () {
            const storageKey = 'kpi_drawer_collapsed';
            const drawer = document.getElementById('kpiDrawer');
            const btn = document.getElementById('btnToggleKpis');
            const txt = document.getElementById('kpiToggleText');
            const icon = document.getElementById('kpiToggleIcon');

            if (!drawer || !btn || !txt || !icon) return;

            function setState(collapsed) {
                drawer.classList.toggle('is-collapsed', collapsed);
                btn.setAttribute('aria-expanded', (!collapsed).toString());
                txt.textContent = collapsed ? 'Expandir' : 'Recolher';

                icon.classList.remove('bi-chevron-up', 'bi-chevron-down');
                icon.classList.add(collapsed ? 'bi-chevron-down' : 'bi-chevron-up');

                localStorage.setItem(storageKey, collapsed ? '1' : '0');
            }

            // padrão: aberto, mas respeita preferência
            const startCollapsed = localStorage.getItem(storageKey) === '1';
            setState(startCollapsed);

            btn.addEventListener('click', () => {
                const collapsed = drawer.classList.contains('is-collapsed');
                setState(!collapsed);
            });
        })();
    </script>
    <script>
        // ======== Linha do chamado clicável (substitui botão "Atender") =========
        document.addEventListener('click', function (e) {
            const tr = e.target.closest('#tabela-painel tbody tr[data-href]');
            if (!tr) return;

            // Evita navegação quando o clique for em um elemento interativo
            if (e.target.closest('a, button, input, select, textarea, label')) return;

            const href = tr.getAttribute('data-href');
            if (href) window.location.href = href;
        });
    </script>
}
