@model IEnumerable<PortalHelpdeskTI.Models.GridTecnicoItemVM>
@using PortalHelpdeskTI.Helpers

<table class="table align-middle mb-0" id="tabela-painel">
    <thead>
        <tr>
            <th data-sort-key="id" data-sort-type="number">
                <button type="button" class="btn btn-link sort-column-btn">
                    <span>#</span>
                    <i class="bi bi-arrow-down-up sort-icon" aria-hidden="true"></i>
                    <span class="visually-hidden">Ordenar por número do chamado</span>
                </button>
            </th>
            <th class="col-titulo" data-sort-key="titulo" data-sort-type="text">
                <button type="button" class="btn btn-link sort-column-btn">
                    <span>Título</span>
                    <i class="bi bi-arrow-down-up sort-icon" aria-hidden="true"></i>
                    <span class="visually-hidden">Ordenar por título</span>
                </button>
            </th>
            <th data-sort-key="prioridade" data-sort-type="priority">
                <button type="button" class="btn btn-link sort-column-btn">
                    <span>Prioridade</span>
                    <i class="bi bi-arrow-down-up sort-icon" aria-hidden="true"></i>
                    <span class="visually-hidden">Ordenar por prioridade</span>
                </button>
            </th>
            <th data-sort-key="sla" data-sort-type="number">
                <button type="button" class="btn btn-link sort-column-btn">
                    <span>SLA</span>
                    <i class="bi bi-arrow-down-up sort-icon" aria-hidden="true"></i>
                    <span class="visually-hidden">Ordenar por SLA</span>
                </button>
            </th>
            <th data-sort-key="solicitante" data-sort-type="text">
                <button type="button" class="btn btn-link sort-column-btn">
                    <span>Solicitante</span>
                    <i class="bi bi-arrow-down-up sort-icon" aria-hidden="true"></i>
                    <span class="visually-hidden">Ordenar por solicitante</span>
                </button>
            </th>
            <th data-sort-key="tecnico" data-sort-type="text">
                <button type="button" class="btn btn-link sort-column-btn">
                    <span>Técnico</span>
                    <i class="bi bi-arrow-down-up sort-icon" aria-hidden="true"></i>
                    <span class="visually-hidden">Ordenar por técnico</span>
                </button>
            </th>
            <th data-sort-key="status" data-sort-type="text">
                <button type="button" class="btn btn-link sort-column-btn">
                    <span>Status</span>
                    <i class="bi bi-arrow-down-up sort-icon" aria-hidden="true"></i>
                    <span class="visually-hidden">Ordenar por status</span>
                </button>
            </th>
            <th class="text-center">Ações</th>
        </tr>
    </thead>

    <tbody id="corpo-tabela-tecnico">
        @foreach (var item in Model)
        {
            var chamado = item.Chamado;
            var solicitante = chamado.Usuario?.Nome ?? "";
            var tecnico = chamado.Tecnico?.Nome ?? "Não atribuído";
            var destaque = ViewBag.NovosChamados != null && ((List<int>)ViewBag.NovosChamados).Contains(chamado.Id)
                ? "table-warning"
                : "";

            <tr data-id="@chamado.Id"
                data-href="/Chamados/Atender/@chamado.Id"
                data-sort-id="@chamado.Id"
                data-sort-titulo="@chamado.Titulo"
                data-sort-prioridade="@chamado.Prioridade"
                data-sort-sla="@item.SlaPercent"
                data-sort-solicitante="@solicitante"
                data-sort-tecnico="@tecnico"
                data-sort-status="@chamado.Status"
                data-search="@($"{chamado.Id} {chamado.Titulo} {solicitante}")"
                class="@destaque chamado-row-click">
                <td>@chamado.Id</td>
                <td class="col-titulo">
                    <span class="titulo-text" title="@chamado.Titulo">@chamado.Titulo</span>
                </td>
                <td>
                    <span class="badge @BadgeHelper.GetPrioridadeBadgeClass(chamado.Prioridade)">
                        @chamado.Prioridade
                    </span>
                </td>
                <td class="col-sla">
                    <div class="progress" style="height: 18px;" title="@item.SlaLabel">
                        <div class="progress-bar @item.SlaCss"
                             role="progressbar"
                             style="width:@item.SlaPercent%;"
                             aria-valuenow="@item.SlaPercent"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @item.SlaPercent%
                        </div>
                    </div>
                    <small class="sla-legend d-block mt-1">
                        @item.SlaLabel
                        @if (item.SlaPaused)
                        {
                            <span class="text-muted"> - pausado (Aguardando)</span>
                        }
                    </small>
                </td>
                <td class="col-nome" title="@solicitante">@solicitante</td>
                <td class="col-nome" title="@tecnico">@tecnico</td>
                <td>
                    <span class="badge @BadgeHelper.GetStatusBadgeClass(chamado.Status)">
                        @chamado.Status
                    </span>
                </td>
                <td class="text-center">
                    <div class="position-relative d-inline-block">
                        <a href="/Chamados/Atender/@chamado.Id" class="btn btn-sm btn-primary botao-visualizar">
                            Atender
                            @if (ViewBag.NovosChamados != null && ((List<int>)ViewBag.NovosChamados).Contains(chamado.Id))
                            {
                                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                    <span class="visually-hidden">Novo</span>
                                </span>
                            }
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
